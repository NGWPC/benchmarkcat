{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.stacspec.org/v1.0.0/collection-spec/json-schema/collection.json#",
  "title": "GFM STAC Collection Specification",
  "description": "This object represents a schema for a STAC GFM collection.",
  "allOf": [
    {
      "$ref": "#/definitions/collection"
    }
  ],
  "definitions": {
    "collection": {
      "title": "Benchmark STAC Collection",
      "description": "These are the fields specific to a Benchmark STAC Collection. All other fields are inherited from STAC Catalog.",
      "type": "object",
      "required": [
        "stac_version",
        "type",
        "id",
        "description",
        "license",
        "extent",
        "links",
        "item_assets",
        "providers"
      ],
      "properties": {
        "stac_version": {
          "title": "STAC version",
          "type": "string",
          "enum": ["1.0.0", "1.1.0"]
        },
        "stac_extensions": {
          "title": "STAC extensions",
          "type": "array",
          "uniqueItems": true,
          "items": {
            "title": "Reference to a JSON Schema",
            "type": "string",
            "format": "iri"
          },
          "default": [
            "https://stac-extensions.github.io/item-assets/v1.0.0/schema.json"
          ]
        },
        "type": {
          "title": "Type of STAC entity",
          "const": "Collection"
        },
        "id": {
          "title": "Identifier",
          "type": "string",
          "minLength": 1
        },
        "title": {
          "title": "Title",
          "type": "string"
        },
        "description": {
          "title": "Description",
          "type": "string",
          "minLength": 1
        },
        "keywords": {
          "title": "Keywords",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "license": {
          "title": "Collection License Name",
          "type": "string",
          "pattern": "^[\\w\\-\\.\\+]+$"
        },
        "providers": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "name"
            ],
            "properties": {
              "name": {
                "title": "Organization name",
                "type": "string"
              },
              "description": {
                "title": "Organization description",
                "type": "string"
              },
              "roles": {
                "title": "Organization roles",
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": [
                    "producer",
                    "licensor",
                    "processor",
                    "host"
                  ]
                }
              },
              "url": {
                "title": "Organization homepage",
                "type": "string",
                "format": "iri"
              }
            }
          }
        },
        "extent": {
          "title": "Extents",
          "type": "object",
          "required": [
            "spatial",
            "temporal"
          ],
          "properties": {
            "spatial": {
              "title": "Spatial extent object",
              "type": "object",
              "required": [
                "bbox"
              ],
              "properties": {
                "bbox": {
                  "title": "Spatial extents",
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "title": "Spatial extent",
                    "type": "array",
                    "oneOf": [
                      {
                        "minItems": 4,
                        "maxItems": 4
                      },
                      {
                        "minItems": 6,
                        "maxItems": 6
                      }
                    ],
                    "items": {
                      "type": "number"
                    }
                  }
                }
              }
            },
            "temporal": {
              "title": "Temporal extent object",
              "type": "object",
              "required": [
                "interval"
              ],
              "properties": {
                "interval": {
                  "title": "Temporal extents",
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "title": "Temporal extent",
                    "type": "array",
                    "minItems": 2,
                    "maxItems": 2,
                    "items": {
                      "type": [
                        "string",
                        "null"
                      ],
                      "format": "date-time",
                      "pattern": "(\\+00:00|Z)$"
                    }
                  }
                }
              }
            }
          }
        },
        "assets": {
          "title": "Assets",
          "type": "object",
          "properties": {
            "observed_flood_extent": {
              "type": "object",
              "properties": {
                "href": {
                  "type": "string"
                },
                "type": {
                  "const": "image/tiff; application=geotiff"
                },
                "title": {
                  "type": "string",
                  "const": "Observed flood extent"
                },
                "description": {
                  "type": "string",
                  "const": "Flooded areas mapped by applying the GFM ensemble flood mapping algorithm to the latest Sentinel-1 images of SAR backscatter intensity."
                },
                "roles": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "const": "data"
                  }
                }
              }
            },
            "observed_water_extent": {
              "type": "object",
              "properties": {
                "href": {
                  "type": "string"
                },
                "type": {
                  "const": "image/tiff; application=geotiff"
                },
                "title": {
                  "type": "string",
                  "const": "Observed water extent"
                },
                "description": {
                  "type": "string",
                  "const": "Open and calm water mapped as the union of the observed flood extent and the reference water mask."
                },
                "roles": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "const": "data"
                  }
                }
              }
            },
            "reference_water_mask": {
              "type": "object",
              "properties": {
                "href": {
                  "type": "string"
                },
                "type": {
                  "const": "image/tiff; application=geotiff"
                },
                "title": {
                  "type": "string",
                  "const": "Reference water mask"
                },
                "description": {
                  "type": "string",
                  "const": "Normal (i.e. permanent and seasonal) water mapped by applying the GFM ensemble water mapping algorithm to a historical five-year time-series (“data cube”) of Sentinel-1 images of SAR backscatter intensity."
                },
                "roles": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "const": "data"
                  }
                }
              }
            },
            "exclusion_mask": {
              "type": "object",
              "properties": {
                "href": {
                  "type": "string"
                },
                "type": {
                  "const": "image/tiff; application=geotiff"
                },
                "title": {
                  "type": "string",
                  "const": "Exclusion mask"
                },
                "description": {
                  "type": "string",
                  "const": "Areas where SAR-based water mapping is not technically feasible, due to no sensitivity (e.g. urban areas, dense vegetation), low backscatter (e.g. flat impervious areas, sandy surfaces), topographic distortions, radar shadows, or low coverage of Sentinel-1."
                },
                "roles": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "const": "data"
                  }
                }
              }
            },
            "likelihood_values": {
              "type": "object",
              "properties": {
                "href": {
                  "type": "string"
                },
                "type": {
                  "const": "image/tiff; application=geotiff"
                },
                "title": {
                  "type": "string",
                  "const": "Likelihood values"
                },
                "description": {
                  "type": "string",
                  "const": "Estimated likelihood of flood classification, for all areas outside the exclusion mask."
                },
                "roles": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "const": "data"
                  }
                }
              }
            },
            "affected_landcover": {
              "type": "object",
              "properties": {
                "href": {
                  "type": "string"
                },
                "type": {
                  "const": "image/tiff; application=geotiff"
                },
                "title": {
                  "type": "string",
                  "const": "Affected landcover"
                },
                "description": {
                  "type": "string",
                  "const": "Land cover / use (e.g. artificial surfaces, agricultural areas) in flooded areas, mapped by a spatial overlay of observed flood extent and the Copernicus GLS land cover."
                },
                "roles": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "const": "data"
                  }
                }
              }
            },
            "affected_population": {
              "type": "object",
              "properties": {
                "href": {
                  "type": "string"
                },
                "type": {
                  "const": "image/tiff; application=geotiff"
                },
                "title": {
                  "type": "string",
                  "const": "Affected population"
                },
                "description": {
                  "type": "string",
                  "const": "Number of people in flooded areas, mapped by a spatial overlay of observed flood extent and gridded population, from the Copernicus GHSL project."
                },
                "roles": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "const": "data"
                  }
                }
              }
            },
            "advisory_flags": {
              "type": "object",
              "properties": {
                "href": {
                  "type": "string"
                },
                "type": {
                  "const": "image/tiff; application=geotiff"
                },
                "title": {
                  "type": "string",
                  "const": "Advisory flags"
                },
                "description": {
                  "type": "string",
                  "const": "Flags indicating potential reduced quality of flood mapping, due to prevailing environmental conditions (e.g. wind, ice, snow, dry soil), or degraded input data quality due to signal interference from other SAR missions."
                },
                "roles": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "const": "data"
                  }
                }
              }
            },
            "sentinel_1_metadata": {
              "type": "object",
              "properties": {
                "href": {
                  "type": "string"
                },
                "type": {
                  "const": "application/json"
                },
                "title": {
                  "type": "string",
                  "const": "Sentinel-1 metadata"
                },
                "description": {
                  "type": "string",
                  "const": "Information on the acquisition parameters of the Sentinel-1 data used."
                },
                "roles": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "const": "metadata"
                  }
                }
              }
            },
            "dfo_event_footprint": {
              "type": "object",
              "properties": {
                "href": {
                  "type": "string"
                },
                "type": {
                  "const": "application/geo+json"
                },
                "title": {
                  "type": "string",
                  "const": "DFO event footprint"
                },
                "description": {
                  "type": "string",
                  "const": "This is the DFO footprint that was identified as intersecting with the scene."
                },
                "roles": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "const": "data"
                  }
                }
              }
            }
          }
        },
        "links": {
          "title": "Links",
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "rel",
              "href"
            ],
            "properties": {
              "rel": {
                "title": "Link relation type",
                "type": "string",
                "minLength": 1
              },
              "href": {
                "title": "Link reference",
                "type": "string",
                "format": "iri-reference",
                "minLength": 1
              },
              "type": {
                "title": "Link type",
                "type": "string"
              },
              "title": {
                "title": "Link title",
                "type": "string"
              }
            }
          },
          "default": [
            {
              "rel": "about",
              "type": "text/html",
              "href": "https://extwiki.eodc.eu/GFM/PUM/TechnicalOverview"
            }
          ]
        },
        "item_assets": {
          "type": "object",
          "title": "Item Assets",
          "description": "This is the way that we will specify asset roles for the collection."
        },
        "provider": {
          "type": "object",
          "title": "Provider",
          "description": "Links out to GLOFAS."
        },
        "summaries": {
          "$ref": "#/definitions/summaries"
        }
      }
    },
    "link": {
      "type": "object",
      "required": [
        "rel",
        "href"
      ],
      "properties": {
        "href": {
          "title": "Link reference",
          "type": "string",
          "format": "iri-reference",
          "minLength": 1
        },
        "rel": {
          "title": "Link relation type",
          "type": "string",
          "minLength": 1
        },
        "type": {
          "title": "Link type",
          "type": "string"
        },
        "title": {
          "title": "Link title",
          "type": "string"
        }
      }
    },
    "summaries": {
      "type": "object",
      "additionalProperties": {
        "anyOf": [
          {
            "title": "JSON Schema",
            "type": "object",
            "minProperties": 1,
            "allOf": [
              {
                "$ref": "http://json-schema.org/draft-07/schema"
              }
            ]
          },
          {
            "title": "Range",
            "type": "object",
            "required": [
              "minimum",
              "maximum"
            ],
            "properties": {
              "minimum": {
                "title": "Minimum value",
                "type": [
                  "number",
                  "string"
                ]
              },
              "maximum": {
                "title": "Maximum value",
                "type": [
                  "number",
                  "string"
                ]
              }
            }
          },
          {
            "title": "Set of values",
            "type": "array",
            "minItems": 1,
            "items": {
              "description": "For each field only the original data type of the property can occur (except for arrays), but we can't validate that in JSON Schema yet. See the summary description in the STAC specification for details."
            }
          }
        ]
      }
    }
  }
}
