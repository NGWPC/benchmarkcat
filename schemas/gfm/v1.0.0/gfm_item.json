{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "GFM STAC Item",
  "type": "object",
  "description": "This object represents the metadata for an item in the GFM STAC collection.",
  "allOf": [
    {
      "$ref": "#/definitions/core"
    }
  ],
  "definitions": {
    "common_metadata": {
      "allOf": [
        {
          "$ref": "../../common_item_metadata/basics.json"
        },
        {
          "$ref": "../../common_item_metadata/datetime.json"
        },
        {
          "$ref": "../../common_item_metadata/instrument.json"
        },
        {
          "$ref": "../../common_item_metadata/licensing.json"
        },
        {
          "$ref": "../../common_item_metadata/provider.json"
        }
      ]
    },
    "core": {
      "allOf": [
        {
          "$ref": "https://geojson.org/schema/Feature.json"
        },
        {
          "type": "object",
          "required": [
            "geometry",
            "bbox"
          ],
          "properties": {
            "geometry": {
              "$ref": "https://geojson.org/schema/Geometry.json"
            },
            "bbox": {
              "type": "array",
              "oneOf": [
                {
                  "minItems": 4,
                  "maxItems": 4
                },
                {
                  "minItems": 6,
                  "maxItems": 6
                }
              ],
              "items": {
                "type": "number"
              }
            }
          }
        },
        {
          "type": "object",
          "required": [
            "stac_version",
            "id",
            "links",
            "assets",
            "properties"
          ],
          "properties": {
            "stac_version": {
              "title": "STAC version",
              "type": "string",
              "enum": ["1.0.0", "1.1.0"]
            },
            "stac_extensions": {
              "title": "STAC extensions",
              "type": "array",
              "uniqueItems": true,
              "items": {
                "title": "Reference to a JSON Schema",
                "type": "string",
                "format": "iri"
              }
            },
            "id": {
              "title": "Provider ID",
              "description": "Provider item ID",
              "type": "string",
              "minLength": 1
            },
            "links": {
              "title": "Item links",
              "description": "Links to item relations",
              "type": "array",
              "items": {
                "type": "object",
                "required": [
                  "rel",
                  "href"
                ],
                "properties": {
                  "rel": {
                    "title": "Link relation type",
                    "type": "string",
                    "minLength": 1
                  },
                  "href": {
                    "title": "Link reference",
                    "type": "string",
                    "format": "iri-reference",
                    "minLength": 1
                  },
                  "type": {
                    "title": "Link type",
                    "type": "string"
                  },
                  "title": {
                    "title": "Link title",
                    "type": "string"
                  }
                }
              },
              "default": [
                {
                  "rel": "about",
                  "type": "text/html",
                  "href": "https://extwiki.eodc.eu/GFM/PUM/TechnicalOverview"
                }
              ]
            },
            "assets": {
              "$ref": "#/definitions/assets"
            },
            "properties": {
              "allOf": [
                {
                  "$ref": "#/definitions/common_metadata"
                },
                {
                  "anyOf": [
                    {
                      "required": [
                        "datetime"
                      ],
                      "properties": {
                        "datetime": {
                          "not": {
                            "type": "null"
                          }
                        }
                      }
                    },
                    {
                      "required": [
                        "datetime",
                        "start_datetime",
                        "end_datetime"
                      ]
                    }
                  ]
                }
              ]
            },
            "sat:orbit_state": {
              "title": "Satellite Orbit State",
              "type": "string",
              "description": "Either ascending or descending.",
              "required": true
            },
            "sat:relative_orbit": {
              "title": "Relative Orbit Number",
              "type": "integer",
              "description": "The relative orbit number at the time of acquisition. Using the relative orbit number associated with the earliest acquired tile in the item.",
              "required": true
            },
            "start_datetime": {
              "title": "Start Datetime",
              "type": "string",
              "description": "The start time of acquisition for all the tiles associated with the event. Finer grained capture times will be included at the asset level.",
              "required": true
            },
            "end_datetime": {
              "title": "End Datetime",
              "type": "string",
              "description": "The end time of acquisition for all the tiles associated with the event. Finer grained capture times will be included at the asset level.",
              "required": true
            },
            "version": {
              "title": "Version",
              "type": "string",
              "description": "Use the version extension to indicate the version of the GFM product associated with this product being used. Since right now all the layers for a given tileset will be coming from the same version this can be at the item level.",
              "required": false
            },
            "layers": {
              "type": "object",
              "description": "This is an object obtained using the layer file. It will specify the id of the asset and then give the label values and color mapping for each layer.",
              "required": true,
              "properties": {
                "observed_flood_extent": {
                  "title": "Observed Flood Extent",
                  "type": "object",
                  "properties": {
                    "label": {
                      "type": "string",
                      "const": "Floodwater"
                    },
                    "quantity": {
                      "type": "number",
                      "const": 1
                    },
                    "color": {
                      "type": "string",
                      "const": "#e84c78"
                    }
                  }
                },
                "observed_water_extent": {
                  "title": "Observed Water Extent",
                  "type": "object",
                  "properties": {
                    "label": {
                      "type": "string",
                      "const": "Water"
                    },
                    "quantity": {
                      "type": "number",
                      "const": 1
                    },
                    "color": {
                      "type": "string",
                      "const": "#0584AA"
                    }
                  }
                },
                "reference_water_mask": {
                  "title": "Reference Water Mask",
                  "type": "object",
                  "properties": {
                    "labels": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "label": {
                            "type": "string"
                          },
                          "quantity": {
                            "type": "number"
                          },
                          "color": {
                            "type": "string"
                          },
                          "opacity": {
                            "type": "string"
                          }
                        }
                      }
                    }
                  }
                },
                "exclusion_mask": {
                  "title": "Exclusion Mask",
                  "type": "object",
                  "properties": {
                    "label": {
                      "type": "string",
                      "const": "Exclusion Mask set"
                    },
                    "quantity": {
                      "type": "number",
                      "const": 1
                    },
                    "color": {
                      "type": "string",
                      "const": "#858686"
                    }
                  }
                },
                "likelihood_values": {
                  "title": "Likelihood Values",
                  "type": "object",
                  "properties": {
                    "labels": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "label": {
                            "type": "string"
                          },
                          "quantity": {
                            "type": "number"
                          },
                          "color": {
                            "type": "string"
                          }
                        }
                      }
                    }
                  }
                },
                "affected_landcover": {
                  "title": "Affected Landcover",
                  "type": "object",
                  "properties": {
                    "labels": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "label": {
                            "type": "string"
                          },
                          "quantity": {
                            "type": "number"
                          },
                          "color": {
                            "type": "string"
                          }
                        }
                      }
                    }
                  }
                },
                "affected_population": {
                  "title": "Affected Population",
                  "type": "object",
                  "properties": {
                    "labels": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "label": {
                            "type": "string"
                          },
                          "quantity": {
                            "type": "number"
                          },
                          "color": {
                            "type": "string"
                          }
                        }
                      }
                    }
                  }
                },
                "advisory_flags": {
                  "title": "Advisory Flags",
                  "type": "object",
                  "properties": {
                    "labels": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "label": {
                            "type": "string"
                          },
                          "quantity": {
                            "type": "number"
                          },
                          "color": {
                            "type": "string"
                          }
                        }
                      }
                    }
                  }
                }
              }
            },
            "license": {
              "title": "License",
              "type": "string",
              "description": "CC-BY-4.0 (recording GFM SPDX license identifier here)",
              "required": true
            }
          }
        }
      ]
    },
    "link": {
      "type": "object",
      "required": [
        "rel",
        "href"
      ],
      "properties": {
        "href": {
          "title": "Link reference",
          "type": "string",
          "format": "iri-reference",
          "minLength": 1
        },
        "rel": {
          "title": "Link relation type",
          "type": "string",
          "minLength": 1
        },
        "type": {
          "title": "Link type",
          "type": "string"
        },
        "title": {
          "title": "Link title",
          "type": "string"
        }
      }
    },
    "assets": {
      "title": "Asset links",
      "description": "Links to assets",
      "type": "object",
      "additionalProperties": {
        "$ref": "#/definitions/asset"
      }
    },
    "asset": {
      "allOf": [
        {
          "type": "object",
          "required": [
            "href"
          ],
          "properties": {
            "href": {
              "title": "Asset reference",
              "type": "string",
              "format": "iri-reference",
              "minLength": 1
            },
            "title": {
              "title": "Asset title",
              "type": "string"
            },
            "description": {
              "title": "Asset description",
              "type": "string"
            },
            "type": {
              "title": "Asset type",
              "type": "string"
            },
            "roles": {
              "title": "Asset roles",
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        {
          "$ref": "#/definitions/common_metadata"
        }
      ]
    },
    "layers": {
      "type": "object",
      "properties": {
        "observed_flood_extent": {
          "title": "Observed Flood Extent",
          "type": "object",
          "properties": {
            "label": {
              "type": "string",
              "const": "Floodwater"
            },
            "quantity": {
              "type": "number",
              "const": 1
            },
            "color": {
              "type": "string",
              "const": "#e84c78"
            }
          }
        },
        "observed_water_extent": {
          "title": "Observed Water Extent",
          "type": "object",
          "properties": {
            "label": {
              "type": "string",
              "const": "Water"
            },
            "quantity": {
              "type": "number",
              "const": 1
            },
            "color": {
              "type": "string",
              "const": "#0584AA"
            }
          }
        },
        "reference_water_mask": {
          "title": "Reference Water Mask",
          "type": "object",
          "properties": {
            "labels": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "label": {
                    "type": "string"
                  },
                  "quantity": {
                    "type": "number"
                  },
                  "color": {
                    "type": "string"
                  },
                  "opacity": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "exclusion_mask": {
          "title": "Exclusion Mask",
          "type": "object",
          "properties": {
            "label": {
              "type": "string",
              "const": "Exclusion Mask set"
            },
            "quantity": {
              "type": "number",
              "const": 1
            },
            "color": {
              "type": "string",
              "const": "#858686"
            }
          }
        },
        "likelihood_values": {
          "title": "Likelihood Values",
          "type": "object",
          "properties": {
            "labels": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "label": {
                    "type": "string"
                  },
                  "quantity": {
                    "type": "number"
                  },
                  "color": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "affected_landcover": {
          "title": "Affected Landcover",
          "type": "object",
          "properties": {
            "labels": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "label": {
                    "type": "string"
                  },
                  "quantity": {
                    "type": "number"
                  },
                  "color": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "affected_population": {
          "title": "Affected Population",
          "type": "object",
          "properties": {
            "labels": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "label": {
                    "type": "string"
                  },
                  "quantity": {
                    "type": "number"
                  },
                  "color": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "advisory_flags": {
          "title": "Advisory Flags",
          "type": "object",
          "properties": {
            "labels": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "label": {
                    "type": "string"
                  },
                  "quantity": {
                    "type": "number"
                  },
                  "color": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}