{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "~/benchmarkcat/schemas/usgs-fim/v1.0.0/usgs-fim_collection.json#",
  "title": "USGS-FIM Collection Specification",
  "description": "This object represents USGS Flood Inundation Mapping (FIM) data Collections in a SpatioTemporal Asset Catalog (STAC). The schema is adapted from the STAC spec v1.",
  "allOf": [
    {
      "$ref": "#/definitions/collection"
    }
  ],
  "definitions": {
    "collection": {
      "title": "USGS-FIM STAC Collection",
      "description": "These are the fields specific to a USGS-FIM STAC Collection. All other fields are inherited from the STAC Catalog.",
      "type": "object",
      "required": [
        "stac_version",
        "type",
        "id",
        "description",
        "license",
        "extent",
        "links",
        "assets"
      ],
      "properties": {
        "stac_version": {
          "title": "STAC version",
          "type": "string",
          "const": "1.0.0"
        },
        "stac_extensions": {
          "title": "STAC extensions",
          "type": "array",
          "uniqueItems": true,
          "items": {
            "title": "Reference to a JSON Schema",
            "type": "string",
            "format": "iri"
          },
          "default": [
            "https://stac-extensions.github.io/item-assets/v1.0.0/schema.json"
          ]
        },
        "type": {
          "title": "Type of STAC entity",
          "const": "Collection"
        },
        "id": {
          "title": "Identifier",
          "type": "string",
          "minLength": 1
        },
        "title": {
          "title": "Title",
          "type": "string"
        },
        "description": {
          "title": "Description",
          "type": "string",
          "minLength": 1
        },
        "license": {
          "title": "Collection License Name",
          "type": "string",
          "pattern": "^[\\w\\-\\.\\+]+$"
        },
        "providers": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "name"
            ],
            "properties": {
              "name": {
                "title": "Organization name",
                "type": "string"
              },
              "description": {
                "title": "Organization description",
                "type": "string"
              },
              "roles": {
                "title": "Organization roles",
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": [
                    "producer",
                    "licensor",
                    "processor",
                    "host"
                  ]
                }
              },
              "url": {
                "title": "Organization homepage",
                "type": "string",
                "format": "iri"
              }
            }
          }
        },
        "extent": {
          "title": "Extents",
          "type": "object",
          "required": [
            "spatial",
            "temporal"
          ],
          "properties": {
            "spatial": {
              "title": "Spatial extent object",
              "type": "object",
              "required": [
                "bbox"
              ],
              "properties": {
                "bbox": {
                  "title": "Spatial extents",
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "title": "Spatial extent",
                    "type": "array",
                    "oneOf": [
                      {
                        "minItems": 4,
                        "maxItems": 4
                      },
                      {
                        "minItems": 6,
                        "maxItems": 6
                      }
                    ],
                    "items": {
                      "type": "number"
                    }
                  }
                }
              }
            },
            "temporal": {
              "title": "Temporal extent object",
              "type": "object",
              "required": [
                "interval"
              ],
              "properties": {
                "interval": {
                  "title": "Temporal extents",
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "title": "Temporal extent",
                    "type": "array",
                    "minItems": 2,
                    "maxItems": 2,
                    "items": {
                      "type": [
                        "string",
                        "null"
                      ],
                      "format": "date-time",
                      "pattern": "(\\+00:00|Z)$"
                    }
                  }
                }
              }
            }
          }
        },
        "assets": {
          "title": "Assets",
          "type": "object",
          "properties": {
            "extent_raster": {
              "type": "object",
              "properties": {
                "href": {
                  "type": "string"
                },
                "type": {
                  "const": "image/tiff; application=geotiff"
                }
              }
            },
            "rating_curve": {
              "type": "object",
              "properties": {
                "href": {
                  "type": "string"
                },
                "type": {
                  "const": "text/csv"
                }
              }
            },
            "flowfile": {
              "type": "object",
              "properties": {
                "href": {
                  "type": "string"
                },
                "type": {
                  "const": "text/csv"
                }
              }
            }
          }
        },
        "links": {
          "title": "Links",
          "type": "array",
          "items": {
            "$ref": "#/definitions/link"
          }
        },
        "summaries": {
          "$ref": "#/definitions/summaries"
        }
      }
    }
  }
}