{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Cross Collection Schema",
  "type": "object",
  "properties": {
    "id": {
      "type": "string"
    },
    "dataset_name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "keywords": {
      "type": "array",
      "items": { "type": "string" }
    },
    "extent": {
      "type": "object",
      "properties": {
        "spatial": {
          "type": "array",
          "items": { "type": "number" },
          "minItems": 4,
          "maxItems": 4
        },
        "temporal": {
          "type": "array",
          "items": {
            "anyOf": [
              { "type": "string", "format": "date-time" },
              { "type": "null" }
            ]
          },
          "minItems": 2,
          "maxItems": 2
        }
      },
      "required": ["spatial", "temporal"]
    },
    "license": {
      "type": "string"
    }
  },
  "required": ["id", "dataset_name", "description", "title", "keywords", "extent", "license"]
}
